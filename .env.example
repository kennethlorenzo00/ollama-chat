# PostgreSQL URL (use postgresql+asyncpg for async driver).
DATABASE_URL=postgresql+asyncpg://ollama:ollama@localhost:5432/ollama_chat

# Secret for JWT signing. Use a long random string in production.
SECRET_KEY=change-me-in-production

# Ollama backend URL (default used in Docker Compose).
OLLAMA_BACKEND_URL=http://ollama:11434
